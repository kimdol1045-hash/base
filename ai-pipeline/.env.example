# Copy this file to .env and fill in private values.
ANTHROPIC_API_KEY=
SKILL_DIR=./skills
LOG_LEVEL=INFO

# ─── Graph RAG ───
GRAPH_RAG_NEO4J_URI=bolt://localhost:7687
GRAPH_RAG_NEO4J_USER=neo4j
# Generate a local password, for example: openssl rand -base64 32
GRAPH_RAG_NEO4J_PASSWORD=
GRAPH_RAG_QDRANT_HOST=localhost
GRAPH_RAG_QDRANT_PORT=6333
GRAPH_RAG_QDRANT_COLLECTION=skills
GRAPH_RAG_OPENAI_API_KEY=
GRAPH_RAG_EMBEDDING_MODEL=text-embedding-3-small
GRAPH_RAG_SKILL_DIR=./skills

# ─── Redis (세션 저장소) ───
REDIS_URL=redis://localhost:6379/0
